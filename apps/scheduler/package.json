{
  "name": "@voai/scheduler",
  "version": "0.0.0",
  "private": true,
  "description": "Scheduler — cron job runner for tenant-scoped recurring tasks (morning briefing, digest, metering rollup)",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
