    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.21"
  },
  "dependencies": {
    "@voai/types": "workspace:*",
    "@voai/telemetry": "workspace:*",
    "@voai/db": "workspace:*",
    "@voai/auth-context": "workspace:*",
    "express": "^4.21.0"
  }
}
