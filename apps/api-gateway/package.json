{
  "name": "@voai/api-gateway",
  "version": "0.0.0",
  "private": true,
  "description": "VirtualOffice AI platform — modular monolith boot process. Registers all service modules in one Node process.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@voai/types": "workspace:*",
    "@voai/config": "workspace:*",
    "@voai/telemetry": "workspace:*",
    "@voai/errors": "workspace:*",
    "@voai/events": "workspace:*",
    "@voai/identity": "workspace:*",
    "@voai/tenancy": "workspace:*",
    "@voai/meeting": "workspace:*",
    "@voai/brain": "workspace:*",
    "@voai/ledger": "workspace:*",
    "@voai/agent-runtime": "workspace:*",
    "@voai/routing": "workspace:*",
    "@voai/performance": "workspace:*",
    "@voai/marketplace": "workspace:*",
    "@voai/marketplace-metering": "workspace:*",
    "@voai/notification": "workspace:*",
    "@voai/admin-console-api": "workspace:*",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
