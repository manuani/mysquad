{
  "name": "@voai/api-server",
  "version": "0.0.0",
  "private": true,
  "description": "VirtualOffice AI platform — API server pool, the modular monolith boot process (§3.7). Registers all service modules in one Node process. Not the edge gateway (§3.1) — that is infra-level, populated in Sprint 1.1.3.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@voai/admin-console-api": "workspace:*",
    "@voai/agent-runtime": "workspace:*",
    "@voai/audit": "workspace:*",
    "@voai/brain": "workspace:*",
    "@voai/config": "workspace:*",
    "@voai/db": "workspace:*",
    "@voai/errors": "workspace:*",
    "@voai/events": "workspace:*",
    "@voai/identity-and-tenancy": "workspace:*",
    "@voai/ledger": "workspace:*",
    "@voai/marketplace": "workspace:*",
    "@voai/marketplace-metering": "workspace:*",
    "@voai/meeting": "workspace:*",
    "@voai/notification": "workspace:*",
    "@voai/performance": "workspace:*",
    "@voai/routing": "workspace:*",
    "@voai/telemetry": "workspace:*",
    "@voai/types": "workspace:*",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
