{
  "name": "@voai/worker",
  "version": "0.0.0",
  "private": true,
  "description": "Background worker pool — BullMQ jobs for async brain indexing, Neo4j graph updates, and DLQ retry.",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@voai/brain": "workspace:*",
    "@voai/config": "workspace:*",
    "@voai/db": "workspace:*",
    "@voai/errors": "workspace:*",
    "@voai/types": "workspace:*",
    "bullmq": "^5.4.2",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
