{
  "name": "@voai/db",
  "version": "0.0.0",
  "private": true,
  "description": "Database access layer — Postgres (with pgvector), Neo4j, Redis, object store clients",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate": "tsx src/migrate.ts",
    "migrate:up": "node-pg-migrate up -d MIGRATIONS_DATABASE_URL",
    "migrate:down": "node-pg-migrate down -d MIGRATIONS_DATABASE_URL",
    "migrate:create": "node-pg-migrate create --migration-file-language sql",
    "seed": "tsx scripts/seed.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.22.4",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "ioredis": "^5.11.1",
    "neo4j-driver": "^6.1.0",
    "pg": "^8.22.0"
  }
}
