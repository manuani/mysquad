{
  "name": "@voai/identity-and-tenancy",
  "version": "0.0.0",
  "private": true,
  "description": "Identity and Tenancy Service — WorkOS integration, sign-in (Apple/Google/Microsoft/email magic-link), session tokens, tenant model, row-level security, cross-tenant isolation enforcement",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/express": "^4.17.21"
  },
  "dependencies": {
    "@voai/types": "workspace:*",
    "@voai/telemetry": "workspace:*",
    "@voai/errors": "workspace:*",
    "express": "^4.21.0"
  }
}
