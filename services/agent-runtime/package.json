{
  "name": "@voai/agent-runtime",
  "version": "0.0.0",
  "private": true,
  "description": "Agent Runtime — persona loading, contribution generation, sub-agent dispatch, scoped-context invocation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/express": "^4.17.21"
  },
  "dependencies": {
    "@voai/types": "workspace:*",
    "@voai/telemetry": "workspace:*",
    "@voai/errors": "workspace:*",
    "@voai/auth-context": "workspace:*",
    "@voai/config": "workspace:*",
    "@voai/routing": "workspace:*",
    "@voai/db": "workspace:*",
    "@voai/brain": "workspace:*",
    "express": "^4.21.0",
    "@voai/marketplace-metering": "workspace:*",
    "@voai/marketplace": "workspace:*"
  }
}
