{
  "name": "@voai/routing",
  "version": "0.0.0",
  "private": true,
  "description": "Routing Service — multi-provider LLM routing, four-tier classification, tier-based dispatch, failover",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b -w",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1079.0",
    "@voai/auth-context": "workspace:*",
    "@voai/config": "workspace:*",
    "@voai/errors": "workspace:*",
    "@voai/telemetry": "workspace:*",
    "@voai/types": "workspace:*",
    "express": "^4.21.0",
    "openai": "^6.45.0"
  }
}
