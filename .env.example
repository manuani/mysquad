# VirtualOffice AI — environment variables
#
# Copy this file to .env.local for local development. Production secrets are
# managed through the cloud provider's secret manager (Sprint 1.1.3).
#
# Every key here corresponds to a field in @voai/config's PlatformConfigSchema.
# Adding a new key: update both this file and packages/config/src/index.ts.

# -----------------------------------------------------------------------------
# Platform — required
# -----------------------------------------------------------------------------

# Environment: development | staging | production | test
NODE_ENV=development

# Region label for logs and metrics. AWS_REGION or GCP_REGION supported;
# default 'local' is fine for development.
# AWS_REGION=us-west-2
# GCP_REGION=us-central1

# Log level: debug | info | warn | error
LOG_LEVEL=info

# HTTP port for the api-server
PORT=3000

# -----------------------------------------------------------------------------
# Databases — required for service boot beyond the skeleton stage.
# `pnpm run docker:up` brings these up locally via infra/docker/docker-compose.yml.
# -----------------------------------------------------------------------------

# Postgres with pgvector extension. Connects as voai_app — a non-superuser
# role subject to row-level security — not voai (the superuser used only to
# run migrations; superusers bypass RLS regardless of FORCE ROW LEVEL
# SECURITY, so the app must never connect as that role). See
# infra/docker/init/postgres/002_app_role.sql.
DATABASE_URL=postgres://voai_app:voai-app-dev-password@localhost:5432/voai_dev

# Migrations need DDL privileges, so they run as the superuser. Used only
# by `pnpm run db:migrate` — never by the running application.
MIGRATIONS_DATABASE_URL=postgres://voai:voai@localhost:5432/voai_dev

# Neo4j (AuraDB in staging/production; local Neo4j for dev)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=voai-dev-password

# Redis (hot cache for real-time contradiction checks; P95 < 1s requirement)
REDIS_URL=redis://localhost:6379

# Object store (S3/GCS-compatible, §4.2.4). MinIO locally — endpoint and
# credentials below match infra/docker/docker-compose.yml. Omit
# OBJECT_STORE_ENDPOINT in staging/production to use real AWS S3.
OBJECT_STORE_BUCKET=voai-dev
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_ACCESS_KEY_ID=voai
OBJECT_STORE_SECRET_ACCESS_KEY=voai-dev-password
# OBJECT_STORE_REGION=us-east-1

# -----------------------------------------------------------------------------
# Identity — Sprint 1.2 (WorkOS integration)
# -----------------------------------------------------------------------------

# WORKOS_API_KEY=
# WORKOS_CLIENT_ID=

# -----------------------------------------------------------------------------
# Routing — Sprint 2.1.2 (single provider) and Sprint 5.1 (multi-provider)
# -----------------------------------------------------------------------------

# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Real-time meeting — Sprint 2.2 (LiveKit)
# -----------------------------------------------------------------------------

# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=

# -----------------------------------------------------------------------------
# Marketplace metering — Sprint 6.1 (Stripe metered billing)
# -----------------------------------------------------------------------------

# STRIPE_SECRET_KEY=
